# Dashboard listen port (public-facing)
DASHBOARD_PORT=8789

# Bind address (0.0.0.0 for public access, 127.0.0.1 for local only)
DASHBOARD_BIND=0.0.0.0

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Session signing secret (random 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Session lifetime in seconds (default 8 hours)
SESSION_TTL_SEC=28800

# Internal relay-manager URL (must stay on localhost)
RELAY_MANAGER_URL=http://127.0.0.1:8788

# Internal room broker URL (must stay on localhost)
BROKER_URL=http://127.0.0.1:8787

# Set to 1 when serving over HTTPS (adds Secure flag to cookies)
COOKIE_SECURE=0
